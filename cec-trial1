e\n","\n","            if 0.0 < land_percentage <= 0.25:\n","                invalid = (patch_water == 0)\n","                indices = ndimage.distance_transform_edt(invalid, return_distances=False, return_indices=True)\n","                patch_vv[invalid] = patch_vv[tuple(indices[:, invalid])]\n","                patch_vv[invalid] += np.random.normal(0, 0.1, np.sum(invalid))\n","\n","            mean_val, std_val = np.mean(patch_vv), np.std(patch_vv)\n","            norm_patch = (patch_vv - mean_val) / (std_val + 1e-8)\n","            file_patches.append(norm_patch.astype(np.float32))\n","\n","    return file_patches\n","\n","# --- Execution ---\n","all_tifs = glob.glob(os.path.join(INPUT_DIR, \"*.tif\"))\n","print(f\"Scanning for {TARGET_IMAGES} valid images...\")\n","\n","successful_images = 0\n","\n","for tiff_path in all_tifs:\n","    if successful_images >= TARGET_IMAGES:\n","        print(\"\\n✅ Target reached! All necessary data is processed.\")\n","        break\n","\n","    try:\n","        # 1. Attempt to open and read (skips corrupted files)\n","        with rasterio.open(tiff_path) as src:\n","            vv_data = src.read(1)\n","            water_mask = src.read(2)\n","\n","        # 2. Check global water percentage\n","        sea_ratio = np.sum(water_mask == 1) / water_mask.size\n","\n","        # 3. If it has enough ocean, extract patches\n","        if sea_ratio > 0.15:\n","            print(f\"Processing {os.path.basename(tiff_path)} (Sea: {sea_ratio*100:.1f}%)\")\n","            patches = extract_and_clean_patches(vv_data, water_mask)\n","\n","            if len(patches) > 0:\n","                # Save immediately to bypass RAM limits\n","                save_path = os.path.join(OUTPUT_DIR, f'patches_img_{successful_images}.npy')\n","                np.save(save_path, np.array(patches))\n","                print(f\"  -> Saved {len(patches)} patches.\")\n","\n","                successful_images += 1\n","\n","            # Clean up memory\n","            del patches, vv_data, water_mask\n","            gc.collect()\n","\n","    except Exception as e:\n","        # Silently skip the corrupted files GEE left behind\n","        pass\n","\n","if successful_images < TARGET_IMAGES:\n","    print(f\"\\n⚠️ Finished scanning all files, but only found {successful_images} valid images.\")"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":40993,"status":"ok","timestamp":1780641819972,"user":{"displayName":"ATHARVA SINGH 24113027","userId":"04836277123364098479"},"user_tz":-330},"id":"sH5MX4c_hQA6","outputId":"5545245a-402c-452b-ba5c-dce6ac5dc65d"},"outputs":[{"name":"stdout","output_type":"stream","text":["Drive already mounted at /content/drive; to attempt to forcibly remount, call drive.mount(\"/content/drive\", force_remount=True).\n","Found 15 files. Loading incrementally to save RAM...\n","Processed file 1/15...\n","Processed file 2/15...\n","Processed file 3/15...\n","Processed file 4/15...\n","Processed file 5/15...\n","Processed file 6/15...\n","Processed file 7/15...\n","Processed file 8/15...\n","Processed file 9/15...\n","Processed file 10/15...\n","Processed file 11/15...\n","Processed file 12/15...\n","Processed file 13/15...\n","Processed file 14/15...\n","Processed file 15/15...\n","\n","Successfully loaded 78000 base patches. Memory is safe!\n","Splitting base data...\n","\n","✅ Setup Complete! Ready for Step 4 (Model Training)!\n"]}],"source":["import os\n","import glob\n","import numpy as np\n","import tensorflow as tf\n","from sklearn.model_selection import train_test_split\n","import gc\n","from google.colab import drive\n","\n","# 1. Mount the Drive\n","drive.mount('/content/drive')\n","\n","# --- Configuration ---\n","INPUT_DIR = '/content/drive/MyDrive/S1_Processed_Patches'\n","TARGET_BASE_PATCHES = 78000\n","\n","npy_files = glob.glob(os.path.join(INPUT_DIR, \"*.npy\"))\n","print(f\"Found {len(npy_files)} files. Loading incrementally to save RAM...\")\n","\n","# Calculate how many patches we need from each file\n","target_per_file = TARGET_BASE_PATCHES // max(1, len(npy_files))\n","sampled_patches = []\n","\n","# --- 1. Incremental Memory-Safe Loading ---\n","for i, file in enumerate(npy_files):\n","    # Load ONLY one file into memory\n","    data = np.load(file).astype(np.float32)\n","\n","    # Sample it immediately to reduce size\n","    if len(data) > target_per_file:\n","        np.random.seed(42 + i)\n","        indices = np.random.choice(len(data), target_per_file, replace=False)\n","        data = data[indices]\n","\n","    # Store the tiny sample\n","    sampled_patches.append(data)\n","\n","    # Nuke the original large array from RAM before opening the next one\n","    del data\n","    gc.collect()\n","    print(f\"Processed file {i+1}/{len(npy_files)}...\")\n","\n","# Combine the tiny samples into one array\n","base_patches = np.concatenate(sampled_patches, axis=0)\n","del sampled_patches\n","gc.collect()\n","\n","print(f\"\\nSuccessfully loaded {len(base_patches)} base patches. Memory is safe!\")\n","\n","# --- 2. Mock Ground Truth ---\n","# (Replace this with real ECMWF angles later)\n","targets = np.random.uniform(0, 360, len(base_patches)).astype(np.float32)\n","\n","# --- 3. Split Base Data ---\n","print(\"Splitting base data...\")\n","X_base_train, X_base_val, y_base_train, y_base_val = train_test_split(\n","    base_patches, targets, test_size=0.10, random_state=42\n",")\n","\n","del base_patches, targets\n","gc.collect()\n","\n","# --- 4. The On-The-Fly Memory-Safe Generator ---\n","class WindDataGenerator(tf.keras.utils.Sequence):\n","    def __init__(self, base_x, base_y, batch_size=16):\n","        # A base batch of 16 will yield an augmented batch of 96 to the GPU\n","        self.base_x = base_x\n","        self.base_y = base_y\n","        self.batch_size = batch_size\n","        self.indices = np.arange(len(self.base_x))\n","        np.random.shuffle(self.indices)\n","\n","    def __len__(self):\n","        return int(np.ceil(len(self.base_x) / self.batch_size))\n","\n","    def __getitem__(self, index):\n","        batch_idx = self.indices[index * self.batch_size : (index + 1) * self.batch_size]\n","        batch_x = self.base_x[batch_idx]\n","        batch_y = self.base_y[batch_idx]\n","\n","        aug_x, aug_y = [], []\n","        for patch, angle in zip(batch_x, batch_y):\n","            p_exp = patch[..., np.newaxis]\n","            aug_x.append(p_exp)\n","            aug_y.append(angle)\n","            for k in [1, 2, 3]:\n","                aug_x.append(np.rot90(p_exp, k=k))\n","                aug_y.append((angle - 90 * k) % 360)\n","            aug_x.append(np.fliplr(p_exp))\n","            aug_y.append((360 - angle) % 360)\n","            aug_x.append(np.flipud(p_exp))\n","            aug_y.append((180 - angle) % 360)\n","\n","        aug_x = np.array(aug_x, dtype=np.float32)\n","        aug_y = np.array(aug_y, dtype=np.float32)\n","        shuff_idx = np.arange(len(aug_x))\n","        np.random.shuffle(shuff_idx)\n","\n","        return aug_x[shuff_idx], aug_y[shuff_idx]\n","\n","    def on_epoch_end(self):\n","        np.random.shuffle(self.indices)\n","\n","# --- 5. Instantiate Generators ---\n","train_gen = WindDataGenerator(X_base_train, y_base_train, batch_size=16)\n","val_gen = WindDataGenerator(X_base_val, y_base_val, batch_size=16)\n","\n","print(\"\\n✅ Setup Complete! Ready for Step 4 (Model Training)!\")"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":32384,"status":"ok","timestamp":1780642540159,"user":{"displayName":"ATHARVA SINGH 24113027","userId":"04836277123364098479"},"user_tz":-330},"id":"sBabtwkwkBGH","outputId":"e0c5455c-aa4d-44f3-f71b-e12bd9b75bc2"},"outputs":[{"name":"stdout","output_type":"stream","text":["Drive already mounted at /content/drive; to attempt to forcibly remount, call drive.mount(\"/content/drive\", force_remount=True).\n","Found 15 files. Loading and scrubbing NaNs incrementally...\n","\n","🛡️ Scrubbing complete! Destroyed 439108 corrupted patches.\n","Successfully loaded 55525 CLEAN base patches.\n","Splitting base data...\n","\n","✅ Setup Complete! Ready for Step 4 (Model Training)!\n"]}],"source":["import os\n","import glob\n","import numpy as np\n","import tensorflow as tf\n","from sklearn.model_selection import train_test_split\n","import gc\n","from google.colab import drive\n","\n","# 1. Mount the Drive\n","drive.mount('/content/drive')\n","\n","# --- Configuration ---\n","INPUT_DIR = '/content/drive/MyDrive/S1_Processed_Patches'\n","TARGET_BASE_PATCHES = 78000\n","\n","npy_files = glob.glob(os.path.join(INPUT_DIR, \"*.npy\"))\n","print(f\"Found {len(npy_files)} files. Loading and scrubbing NaNs incrementally...\")\n","\n","target_per_file = TARGET_BASE_PATCHES // max(1, len(npy_files))\n","sampled_patches = []\n","total_corrupted = 0\n","\n","# --- 1. Incremental Loading & NaN Scrubbing ---\n","for i, file in enumerate(npy_files):\n","    data = np.load(file).astype(np.float32)\n","\n","    # THE FIX: Hunt down and destroy any patch containing a NaN or Infinity\n","    # We check across the pixel dimensions (axis 1 and 2)\n","    valid_mask = ~np.isnan(data).any(axis=(1, 2)) & ~np.isinf(data).any(axis=(1, 2))\n","\n","    corrupted_count = len(data) - np.sum(valid_mask)\n","    total_corrupted += corrupted_count\n","\n","    # Keep only the valid, clean patches\n","    data = data[valid_mask]\n","\n","    # Sample down to save memory\n","    if len(data) > target_per_file:\n","        np.random.seed(42 + i)\n","        indices = np.random.choice(len(data), target_per_file, replace=False)\n","        data = data[indices]\n","\n","    sampled_patches.append(data)\n","    del data\n","    gc.collect()\n","\n","base_patches = np.concatenate(sampled_patches, axis=0)\n","del sampled_patches\n","gc.collect()\n","\n","print(f\"\\n🛡️ Scrubbing complete! Destroyed {total_corrupted} corrupted patches.\")\n","print(f\"Successfully loaded {len(base_patches)} CLEAN base patches.\")\n","\n","# --- 2. Mock Ground Truth ---\n","targets = np.random.uniform(0, 360, len(base_patches)).astype(np.float32)\n","\n","# --- 3. Split Base Data ---\n","print(\"Splitting base data...\")\n","X_base_train, X_base_val, y_base_train, y_base_val = train_test_split(\n","    base_patches, targets, test_size=0.10, random_state=42\n",")\n","\n","del base_patches, targets\n","gc.collect()\n","\n","# --- 4. The Updated Data Generator ---\n","class WindDataGenerator(tf.keras.utils.Sequence):\n","    # Added **kwargs to fix the PyDataset UserWarning\n","    def __init__(self, base_x, base_y, batch_size=16, **kwargs):\n","        super().__init__(**kwargs)\n","        self.base_x = base_x\n","        self.base_y = base_y\n","        self.batch_size = batch_size\n","        self.indices = np.arange(len(self.base_x))\n","        np.random.shuffle(self.indices)\n","\n","    def __len__(self):\n","        return int(np.ceil(len(self.base_x) / self.batch_size))\n","\n","    def __getitem__(self, index):\n","        batch_idx = self.indices[index * self.batch_size : (index + 1) * self.batch_size]\n","        batch_x = self.base_x[batch_idx]\n","        batch_y = self.base_y[batch_idx]\n","\n","        aug_x, aug_y = [], []\n","        for patch, angle in zip(batch_x, batch_y):\n","            p_exp = patch[..., np.newaxis]\n","            aug_x.append(p_exp)\n","            aug_y.append(angle)\n","            for k in [1, 2, 3]:\n","                aug_x.append(np.rot90(p_exp, k=k))\n","                aug_y.append((angle - 90 * k) % 360)\n","            aug_x.append(np.fliplr(p_exp))\n","            aug_y.append((360 - angle) % 360)\n","            aug_x.append(np.flipud(p_exp))\n","            aug_y.append((180 - angle) % 360)\n","\n","        aug_x = np.array(aug_x, dtype=np.float32)\n","        aug_y = np.array(aug_y, dtype=np.float3