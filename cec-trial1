(x)\n","\n","    outputs = layers.Dense(1, activation='linear')(x)\n","    return models.Model(inputs=inputs, outputs=outputs, name=\"M64RN4_Wind_Net\")\n","\n","resnet_model = build_m64rn4_model()\n","optimizer = tf.keras.optimizers.Adam(learning_rate=1e-4, clipnorm=1.0)\n","resnet_model.compile(optimizer=optimizer, loss=angular_loss)\n","\n","checkpoint_path = '/content/drive/MyDrive/S1_Wind_Project/best_resnet_model.keras'\n","\n","callbacks = [\n","    tf.keras.callbacks.EarlyStopping(monitor='val_loss', patience=15, restore_best_weights=True),\n","    tf.keras.callbacks.ModelCheckpoint(filepath=checkpoint_path, monitor='val_loss', save_best_only=True)\n","]\n","\n","print(\"\\n🚀 Starting Full ResNet Training on GPU...\")\n","print(\"EarlyStopping is active. The model will automatically halt and save when peak accuracy is reached.\")\n","\n","history = resnet_model.fit(\n","    train_gen,\n","    validation_data=val_gen,\n","    epochs=100,\n","    callbacks=callbacks\n",")\n","\n","print(f\"\\n✅ Training complete! Best model weights saved to: {checkpoint_path}\")"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":8254,"status":"ok","timestamp":1780678624816,"user":{"displayName":"ATHARVA SINGH 24113027","userId":"04836277123364098479"},"user_tz":-330},"id":"sp_IfvMZtIok","outputId":"dfea2a25-7434-4649-f36e-ca342cbe23f1"},"outputs":[{"name":"stdout","output_type":"stream","text":["Loading trained ResNet model...\n","✅ Model loaded successfully!\n","\n","Loading test data from patches_img_0.npy...\n","Making predictions...\n","\n","\u001b[1m1/1\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m2s\u001b[0m 2s/step\n","--- Prediction Results ---\n","Patch 1 | Predicted Wind Direction: 044.9°\n","Patch 2 | Predicted Wind Direction: 023.8°\n","Patch 3 | Predicted Wind Direction: 022.8°\n","Patch 4 | Predicted Wind Direction: 017.4°\n","Patch 5 | Predicted Wind 