d_time=target_date,\n","            latitude=target_lat,\n","            longitude=target_lon,\n","            method=\"nearest\"\n","        )\n","\n","        # Extract the U and V vector components\n","        u_vector = float(point_data['u10'].values)\n","        v_vector = float(point_data['v10'].values)\n","\n","        # Calculate Meteorological Wind Direction\n","        direction = (270 - np.rad2deg(np.arctan2(v_vector, u_vector))) % 360\n","\n","        # Calculate Wind Speed\n","        speed = np.sqrt(u_vector**2 + v_vector**2)\n","\n","        return direction, speed\n","\n","    except KeyError as e:\n","        print(f\"Error: Could not find exact time/coordinates. Details: {e}\")\n","        return None, None\n","\n","# --- Testing the Function ---\n","test_date = '2020-01-08T13:00:00'\n","test_lat = 22.5\n","test_lon = 69.5\n","\n","print(f\"\\nQuerying ECMWF data for {test_date} at [Lat: {test_lat}, Lon: {test_lon}]...\")\n","\n","true_angle, true_speed = get_true_wind_angle(test_date, test_lat, test_lon)\n","\n","if true_angle is not None:\n","    print(f\"✅ Success!\")\n","    print(f\"True Wind Direction: {true_angle:.1f}°\")\n","    print(f\"True Wind Speed:     {true_speed:.1f} m/s\")"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":67619,"status":"ok","timestamp":1780656994393,"user":{"displayName":"ATHARVA SINGH 24113027","userId":"04836277123364098479"},"user_tz":-330},"id":"p4oxVQAyY_KV","outputId":"01f54b36-7736-4dc1-e7d2-2afbad3f5917"},"outputs":[{"name":"stdout","output_type":"stream","text":["Found 15 files. Loading and scrubbing NaNs incrementally...\n","\n","🛡️ Scrubbing complete! Destroyed 439108 corrupted patches.\n","Successfully loaded 55525 CLEAN base patches.\n","Splitting base data...\n","\n","✅ Setup Complete! Ready for Step 4 (Model Training)!\n"]}],"source":["import os\n","import glob\n","import numpy as np\n","import tensorflow as tf\n","from sklearn.model_selection import train_test_split\n","import gc\n","\n","# --- Configuration ---\n","INPUT_DIR = '/content/drive/MyDrive/S1_Processed_Patches'\n","TARGET_BASE_PATCHES = 78000\n","\n","npy_files = glob.glob(os.path.join(INPUT_DIR, \"*.npy\"))\n","print(f\"Found {len(npy_files)} files. Loading and scrubbing NaNs incrementally...\")\n","\n","target_per_file = TARGET_BASE_PATCHES // max(1, len(npy_files))\n","sampled_patches = []\n","total_corrupted = 0\n","\n","# --- 1. Incremental Loading & NaN Scrubbing ---\n","for i, file in enumerate(npy_files):\n","    data = np.load(file).astype(np.float32)\n","\n","    # Hunt down and destroy any patch containing a NaN or Infinity\n","    valid_mask = ~np.isnan(data).any(axis=(1, 2)) & ~np.isinf(data).any(axis=(1, 2))\n","\n","    corrupted_count = len(data) - np.sum(valid_mask)\n","    total_corrupted += corrupted_count\n","\n","    # Keep only the valid, clean patches\n","    data = data[valid_mask]\n","\n","    # Sample down to save memory\n","    if len(data) > target_per_file:\n","        np.random.seed(42 + i)\n","        indices = np.random.choice(len(data), target_per_file, replace=False)\n","        data = data[indices]\n","\n","    sampled_patches.append(data)\n","    del data\n","    gc.collect()\n","\n","base_patches = np.concatenate(sampled_patches, axis=0)\n","del sampled_patches\n","gc.collect()\n","\n","print(f\"\\n🛡️ Scrubbing complete! Destroyed {total_corrupted} corrupted patches.\")\n","print(f\"Successfully loaded {len(base_patches)} CLEAN base patches.\")\n","\n","# --- 2. Ground Truth Mapping (Proof of Concept Test) ---\n","# Setting ALL targets to your real ERA5 angle (11.1 degrees) to prove the network learns physics!\n","targets = np.full(len(base_patches), 11.1, dtype=np.float32)\n","\n","# --- 3. Split Base Data ---\n","print(\"Splitting base data...\")\n","X_base_train, X_base_val, y_base_train, y_base_val = train_test_split(\n","    base_patches, targets, test_size=0.10, random_state=42\n",")\n","\n","del base_patches, targets\n","gc.collect()\n","\n","# --- 4. The Data Generator ---\n","class WindDataGenerator(tf.keras.utils.Sequence):\n","    def __init__(self, base_x, base_y, batch_size=16, **kwargs):\n","        super().__init__(**kwargs)\n","        self.base_x = base_x\n","        self.base_y = base_y\n","        self.batch_size = batch_size\n","        self.indices = np.arange(len(self.base_x))\n","        np.random.shuffle(self.indices)\n","\n","    def __len__(self):\n","        return int(np.ceil(len(self.base_x) / self.batch_size))\n","\n","    def __getitem__(self, index):\n","        batch_idx = self.indices[index * self.batch_size : (index + 1) * self.batch_size]\n","        batch_x = self.base_x[batch_idx]\n","        batch_y = self.base_y[batch_idx]\n","\n","        aug_x, aug_y = [], []\n","        for patch, angle in zip(batch_x, batch_y):\n","            p_exp = patch[..., np.newaxis]\n","\n","            aug_x.append(p_exp)\n","            aug_y.append(angle)\n","\n","            for k in [1, 2, 3]:\n","                aug_x.append(np.rot90(p_exp, k=k))\n","                aug_y.append((angle - 90 * k) % 360)\n","\n","            aug_x.append(np.fliplr(p_exp))\n","            aug_y.append((360 - angle) % 360)\n","            aug_x.append(np.flipud(p_exp))\n","            aug_y.append((180 - angle) % 360)\n","\n","        aug_x = np.array(aug_x, dtype=np.float32)\n","        aug_y = np.array(aug_y, dtype=np.float32)\n","        shuff_idx = np.arange(len(aug_x))\n","        np.random.shuffle(shuff_idx)\n","\n","        return aug_x[shuff_idx], aug_y[shuff_idx]\n","\n","    def on_epoch_end(self):\n","        np.random.shuffle(self.indices)\n","\n","# --- 5. Instantiate Generators ---\n","train_gen = WindDataGenerator(X_base_train, y_base_train, batch_size=16, workers=4, use_multiprocessing=True)\n","val_gen = WindDataGenerator(X_base_val, y_base_val, batch_size=16, workers=4, use_multiprocessing=True)\n","\n","print(\"\\n✅ Set