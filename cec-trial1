of patches (e.g., 20x20 grid = 400 patches)\n","        grid_size = 20\n","        num_samples = grid_size * grid_size\n","\n","        if len(clean_data) < num_samples:\n","            num_samples = len(clean_data)\n","            grid_size = int(np.sqrt(num_samples))\n","\n","        indices = np.random.choice(len(clean_data), num_samples, replace=False)\n","        samples = clean_data[indices][..., np.newaxis]\n","\n","        # 3. Predict Angles\n","        predictions = resnet_model.predict(samples, verbose=0)\n","        angles = (predictions.flatten() % 360)\n","\n","        # 4. Convert Angles to U and V Vectors for plotting\n","        angles_rad = np.radians(angles)\n","        U = -np.sin(angles_rad)\n","        V = -np.cos(angles_rad)\n","\n","        # Reshape into a 2D grid for the map\n","        U_grid = U[:grid_size**2].reshape(grid_size, grid_size)\n","        V_grid = V[:grid_size**2].reshape(grid_size, grid_size)\n","\n","        # 5. Generate the Plot (Like your screenshot)\n","        X, Y = np.meshgrid(np.arange(grid_size), np.arange(grid_size))\n","\n","        fig, ax = plt.subplots(figsize=(10, 8))\n","        ax.set_facecolor('#e0e0e0') # Light grey background\n","\n","        # Mocking wind speed array for the color map (since model only predicts direction)\n","        # We add slight random noise just to make the colormap look realistic for the demo\n","        mock_speed = np.random.uniform(5.0, 7.0, size=(grid_size, grid_size))\n","\n","        # Draw the Quiver map\n","        q = ax.quiver(X, Y, U_grid, V_grid, mock_speed,\n","                      cmap='jet', scale=25, width=0.003, headwidth=4)\n","\n","        plt.colorbar(q, label='Wind Speed (m/s) [Simulated for Colormap]')\n","        ax.set_title(f\"SAR Predicted Wind Field - Gujarat Coast ({request.date})\", fontsize=16, fontweight='bold')\n","        ax.set_xticks([])\n","        ax.set_yticks([])\n","\n","        # 6. Save image to memory buffer and return it\n","        buf = io.BytesIO()\n","        plt.savefig(buf, format='png', bbox_inches='tight', dpi=150)\n","        buf.seek(0)\n","        plt.close(fig)\n","\n","        return StreamingResponse(buf, media_type=\"image/png\")\n","\n","    except FileNotFoundError:\n","        raise HTTPException(status_code=404, detail=\"Satellite data not found.\")\n","    except Exception as e:\n","        raise HTTPException(status_code=500, detail=str(e))\n","\n","# --- 6. Launch the Server! ---\n","def run_server():\n","    # FIX: Changed to 0.0.0.0 and port 8081\n","    uvicorn.run(app, host=\"0.0.0.0\", port=8081)\n","\n","server_thread = threading.Thread(target=run_server)\n","server_thread.start()\n","\n","# FIX: Changed to 8081\n","output.serve_kernel_port_as_iframe(8081, path='/docs')"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":35},"executionInfo":{"elapsed":352,"status":"ok","timestamp":1780679497256,"user":{"displayName":"ATHARVA SINGH 24113027","userId":"04836277123364098479"},"user_tz":-330},"id":"vvTWR4cjwsL9","outputId":"10d16867-833f-4bd2-b100-051bf4ab2610"},"outputs":[{"name":"stdout","output_type":"stream","text":["Click here for the Swagger UI: https://8081-m-s-kkb-ase1a0-zansn5alezz2-a.asia-east1-0.prod.colab.devdocs\n"]}],"source":["from google.colab import output\n","url = output.eval_js(\"google.colab.kernel.proxyPort(8081)\")\n","print(f\"Click here for the Swagger UI: {url}docs\")"]},{"cell_type":"code","execution_count":1,"metadata":{"id":"l7b6Rb2DjS12","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1780829844739,"user_tz":-330,"elapsed":347315,"user":{"displayName":"ATHARVA SINGH 24113027","userId":"04836277123364098479"}},"outputId":"87e1c7cd-cb77-4bae-e034-96a967b7909b"},"outputs":[{"output_type":"stream","name":"stdout","text":["Mounted at /content/drive\n","🔍 Scanning directory for 'vv' polarization files...\n","Evaluating 7 files for ocean surface visibility...\n","\n","🏆 Top Files Selected for Extraction:\n","1. 2021-02-14 | Sea: 97.7%\n","2. 2021-02-21 | Sea: 94.7%\n","3. 2021-01-16 | Sea: 94.7%\n","4. 2021-11-24 | Sea: 94.6%\n","5. 2021-11-15 | Sea: 94.3%\n","6. 2021-02-12 | Sea: 94.3%\n","7. 2021-03-27 | Sea: 93.4%\n","\n","🚀 Beginning Incremental Patch Extraction (RAM Safe Mode)...\n","[1/7] Processing 2021-02-14...\n","      -> ✅ Saved 175274 pristine 49x49 patches.\n","[2/7] Processing 2021-02-21...\n","      -> ✅ Saved 196731 pristine 49x49 patches.\n","[3/7] Processing 2021-01-16...\n","      -> ✅ Saved 196731 pristine 49x49 patches.\n","[4/7] Processing 2021-11-24...\n","      -> ✅ Saved 196731 pristine 49x49 patches.\n","[5/7] Processing 2021-11-15...\n","      -> ✅ Saved 195043 pristine 49x49 patches.\n","[6/7] Processing 2021-02-12...\n","      -> ✅ Saved 194879 pristine 49x49 patches.\n","[7/7] Processing 2021-03-27...\n","      -> ✅ Saved 171749 pristine 49x49 patches.\n","\n","🎉 Extraction complete! The raw data is ready for the neural network.\n"]}],"source":["import os\n","import glob\n","import gc\n","import re\n","import numpy as np\n","import rasterio\n","from skimage.util import view_as_windows\n","from datetime import datetime\n","from google.colab import drive\n","\n","# 1. Mount the Drive\n","drive.mount('/content/drive')\n","\n","# --- Configuration ---\n","RAW_DIR = '/content/drive/MyDrive/S1_Test_Images'\n","OUT_DIR = '/content/drive/MyDrive/S1_Processed_Patches'\n","PATCH_SIZE = 49\n","STRIDE = 49 # 0 overlap = massive RAM savings\n","FILES_TO_PROCESS = 50\n","\n","os.makedirs(OUT_DIR, exist_ok=True)\n","\n","# --- 1. Date Extraction Utility ---\n","def extract_date(filename):\n","    \"\"\"Finds the YYYYMMDD pattern in the Sentinel-1 tiff filename.\"\"\"\n","    match = re.search(r'20[1-2][0-9][0-1][0-9][0-3][0-9]', filename)\n","    if match:\n","        return datetime.strptime(match.group(), '%Y%m%d')\n","    return None\n","\n","# --- 2. Sea Percentage Calculator (RAM Safe) ---\n","def calculate_sea_percentage(filepath):\n","    \"\"\"Reads the image at 10% resolution to check for sea pixels.\"\"\"\n","    try:\n","        with rasterio.open(filepath) as src:\n","            # Read at 1/10th scale to save RAM\n","            data = src.read(1, out_shape=(1, int(src.height // 10), int(src.width // 10)))\n","\n","            # Assuming sea pixels are valid data (>0) and not NaNs\n","            valid_sea_mask = (data > 0.0) & ~np.isnan(data)\n","\n","            sea_pixels = np.sum(valid_sea_mask)\n","            total_pixels = data.size\n","\n","            return (sea_pixels / total_pixels) * 100\n","    except Exception as e:\n","        print(f\"Error reading {os.path.basename(filepath)}: {e}\")\n","        return 0.0\n","\n","# --- Phase 1: The Scout ---\n","print(\"🔍 Scanning directory for 'vv' polarization files...\")\n","# Strictly grab the VV files\n","all_vv_files = glob.glob(os.path.join(RAW_DIR, \"*vv*.tiff\"))\n","\n","file_database = []\n","for f in all_vv_files:\n","    f_date = extract_date(os.path.basename(f))\n","    if f_date:\n","        file_database.append({\"path\": f, \"date\": f_date})\n","\n","if not file_database:\n","    print(\"⚠️ No valid VV .tiff files found! Check your folder path and filenames.\")\n","else:\n","    print(f\"Evaluating {len(file_database)} files for ocean surface visibility...\")\n","\n","    # Calculate Sea %\n","    for item in file_database:\n","        item[\"sea_pct\"] = calculate_sea_percentage(item[\"path\"])\n","\n","    # Sort by Highest Sea Percentage\n","    file_database.sort(key=lambda x: x[\"sea_pct\"], reverse=True)\n","    top_files = file_database[:FILES_TO_PROCESS]\n","\n","    print(\"\\n🏆 Top Files Selected for Extraction:\")\n","    for i, item in enumerate(top_files):\n","        print(f\"{i+1}. {item['date'].strftime('%Y-%m-%d')} | Sea: {item['sea_pct']:.1f}%\")\n","\n","    print(\"\\n🚀 Beginning Incremental Patch Extraction (RAM Safe Mode)...\")\n","\n","    # --- Phase 2: The Extractor ---\n","    for i, item in enumerate(top_files):\n","        date_str = item[\"date\"].strftime('%Y-%m-%d')\n","        file_path = item[\"path\"]\n","        out_name = os.path.join(OUT_DIR, f\"patches_{date_str}.npy\")\n","\n","        if os.path.exists(out_name):\n","            print(f\"[{i+1}/{len(top_files)}] Skipping {date_str} (Already processed)\")\n","            continue\n","\n","        print(f\"[{i+1}/{len(top_files)}] Processing {date_str}...\")\n","\n","        try:\n","            with rasterio.open(file_path) as src:\n","                data = src.read(1).astype(np.float32)\n","\n","            # Create sliding windows\n","            patches = view_as_windows(data, (PATCH_SIZE, PATCH_SIZE), step=STRIDE)\n","            patches = patches.reshape(-1, PATCH_SIZE, PATCH_SIZE)\n","\n","            # Filter out land, borders, and NaNs\n","            valid_mask = ~np.isnan(patches).any(axis=(1, 2)) & ~np.isinf(patches).any(axis=(1, 2)) & (np.mean(patches, axis=(1,2)) > 0.05)\n","            clean_patches = patches[valid_mask]\n","\n","            # Save the raw numbers to Drive\n","            np.save(out_name, clean_patches)\n","            print(f\"      -> ✅ Saved {len(clean_patches)} pristine 49x49 patches.\")\n","\n","        except Exception as e:\n","            print(f\"      -> ❌ Failed to process {date_str}: {e}\")\n","\n","        finally:\n","            # Clear the massive arrays out of Colab's RAM instantly\n","            if 'data' in locals(): del data\n","            if 'patches' in locals(): del patches\n","            if 'clean_patches' in locals(): del clean_patches\n","            if 'valid_mask' in locals(): del valid_mask\n","            gc.collect()\n","\n","    print(\"\\n🎉 Extraction complete! The raw data is ready for the neural network.\")"]},{"cell_type":"code","source":["import requests\n","import zipfile\n","from rasterio.io import MemoryFile"],"metadata":{"id":"73yCfup6ycoz","executionInfo":{"status":"ok","timestamp":1780831544780,"user_tz":-330,"elapsed":14,"user":{"displayName":"ATHARVA SINGH 24113027","userId":"04836277123364098479"}}},"execution_count":6,"outputs":[]},{"cell_type":"code","source":["!pip install fastapi uvicorn pydantic matplotlib nest-asyncio -q\n","\n","from fastapi import FastAPI, HTTPException\n","from fastapi.responses import StreamingResponse\n","from pydantic import BaseModel\n","import tensorflow as tf\n","import numpy as np\n","import tensorflow.keras.backend as K\n","import uvicorn\n","import threading\n","import io\n","import os\n","import glob\n","import matplotlib.pyplot as plt\n","from datetime import datetime\n","from google.colab import output\n","\n","# --- 1. Dynamic Directory Scanning ---\n","PATCHES_DIR = '/content/drive/MyDrive/S1_Processed_Patches'\n","\n","def get_available_dates():\n","    available_dates = []\n","    search_pattern = os.path.join(PATCHES_DIR, \"patches_*.npy\")\n","    for filepath in glob.glob(search_pattern):\n","        filename = os.path.basename(filepath)\n","        try:\n","            date_str = filename.replace(\"patches_\", \"\").replace(\".npy\", \"\")\n","            valid_date = datetime.strptime(date_str, \"%Y-%m-%d\")\n","            available_dates.append(valid_date)\n","        except ValueError:\n","            continue\n","    return sorted(available_dates)\n","\n","def find_nearest_date(target_date_str, available_dates):\n","    if not available_dates:\n","        return None\n","    target_date = datetime.strptime(target_date_str, \"%Y-%m-%d\")\n","    closest_date = min(available_dates, key=lambda d: abs(d - target_date))\n","    return closest_date.strftime(\"%Y-%m-%d\")\n","\n","# --- 2. Model Initialization ---\n","def angular_loss(y_true, y_pred):\n","    y_true_rad = y_true * (np.pi / 180.0)\n","    y_pred_rad = y_pred * (np.pi / 180.0)\n","    return 1.0 - K.square(tf.cos(y_pred_rad - y_true_rad))\n","\n","app = FastAPI(title=\"SAR Wind Field API (Production Level)\")\n","\n","print(\"Booting up API and loading ResNet Model...\")\n","model_path = '/content/drive/MyDrive/S1_Wind_Project/best_resnet_model.keras'\n","resnet_model = tf.keras.models.load_model(model_path, custom_objects={'angular_loss': angular_loss})\n","\n","AVAILABLE_DATES_DB = get_available_dates()\n","print(f\"✅ API Ready! Found {len(AVAILABLE_DATES_DB)} satellite passes in the database.\")\n","\n","# --- 3. The Endpoint ---\n","class WindRequest(BaseModel):\n","    date: str\n","\n","@app.post(\"/generate_wind_map\")\n","async def generate_wind_map(request: WindRequest):\n","    try:\n","        datetime.strptime(request.date, \"%Y-%m-%d\")\n","    except ValueError:\n","        raise HTTPException(status_code=400, detail=\"Invalid date format. Use YYYY-MM-DD.\")\n","\n","    if not AVAILABLE_DATES_DB:\n","        raise HTTPException(status_code=500, detail=\"No satellite data found in the Drive folder.\")\n","\n","    nearest_date_str = find_nearest_date(request.date, AVAILABLE_DATES_DB)\n","\n","    try:\n","        file_path = os.path.join(PATCHES_DIR, f'patches_{nearest_date_str}.npy')\n","        test_data = np.load(file_path).astype(np.float32)\n","\n","        # We sample 400 patches to draw a clean 20x20 grid map\n","        grid_size = 20\n","        num_samples = min(grid_size * grid_size, len(test_data))\n","        indices = np.random.choice(len(test_data), num_samples, replace=False)\n","        samples = test_data[indices][..., np.newaxis]\n","\n","        predictions = resnet_model.predict(samples, verbose=0)\n","        angles = (predictions.flatten() % 360)\n","\n","        angles_rad = np.radians(angles)\n","        U = -np.sin(angles_rad)\n","        V = -np.cos(angles_rad)\n","\n","        U_grid = U[:num_samples].reshape(int(np.sqrt(num_samples)), -1)\n","        V_grid = V[:num_samples].reshape(int(np.sqrt(num_samples)), -1)\n","\n","        fig, ax = plt.subplots(figsize=(10, 8))\n","        ax.set_facecolor('#e0e0e0')\n","        X, Y = np.meshgrid(np.arange(U_grid.shape[1]), np.arange(U_grid.shape[0]))\n","        mock_speed = np.random.uniform(5.0, 7.0, size=U_grid.shape)\n","\n","        q = ax.quiver(X, Y, U_grid, V_grid, mock_speed, cmap='jet', scale=25, width=0.003)\n","        plt.colorbar(q, label='Wind Speed (m/s) [Simulated for Colormap]')\n","\n","        if request.date == nearest_date_str:\n","            title = f\"SAR Predicted Wind Field ({nearest_date_str})\"\n","        else:\n","            title = f\"Requested: {request.date} | Nearest Match: {nearest_date_str}\"\n","\n","        ax.set_title(title, fontsize=14, fontweight='bold')\n","        ax.set_xticks([]); ax.set_yticks([])\n","\n","        buf = io.BytesIO()\n","        plt.savefig(buf, format='png', bbox_inches='tight', dpi=150)\n","        buf.seek(0)\n","        plt.close(fig)\n","\n","        return StreamingResponse(buf, media_type=\"image/png\")\n","\n","    except Exception as e:\n","        raise HTTPException(status_code=500, detail=str(e))\n","\n","# --- 4. Server Launch ---\n","def run_server():\n","    # Change port to 8083\n","    uvicorn.run(app, host=\"0.0.0.0\", port=8083)\n","\n","server_thread = threading.Thread(target=run_server)\n","server_thread.start()\n","\n","# Change port to 8083\n","output.serve_kernel_port_as_iframe(8083, path='/docs')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":510},"id":"h9o6MMMvsimz","executionInfo":{"status":"ok","timestamp":1780830762258,"user_tz":-330,"elapsed":8039,"user":{"displayName":"ATHARVA SINGH 24113027","userId":"04836277123364098479"}},"outputId":"b36a1713-c43e-48ab-b6c7-861f2c90d38c"},"execution_count":4,"outputs":[{"output_type":"stream","name":"stdout","text":["Booting up API and loading ResNet Model...\n","✅ API Ready! Found 31 satellite passes in the database.\n"]},{"output_type":"stream","name":"stderr","text":["INFO:     Started server process [1987]\n"]},{"output_type":"display_data","data":{"text/plain":["<IPython.core.display.Javascript object>"],"application/javascript":["(async (port, path, width, height, cache, element) => {\n","    if (!google.colab.kernel.accessAllowed && !cache) {\n","      return;\n","    }\n","    element.appendChild(document.createTextNode(''));\n","    const url = await google.colab.kernel.proxyPort(port, {cache});\n","    const iframe = document.createElement('iframe');\n","    iframe.src = new URL(path, url).toString();\n","    iframe.height = height;\n","    iframe.width = width;\n","    iframe.style.border = 0;\n","    iframe.allow = [\n","        'accelerometer',\n","        'autoplay',\n","        'camera',\n","        'clipboard-read',\n","        'clipboard-write',\n","        'gyroscope',\n","        'magnetometer',\n","        'microphone',\n","        'serial',\n","        'usb',\n","        'xr-spatial-tracking',\n","    ].join('; ');\n","    element.appendChild(iframe);\n","  })(8083, \"/docs\", \"100%\", \"400\", false, window.element)"]},"metadata":{}},{"output_type":"stream","name":"stderr","text":["INFO:     Waiting for application startup.\n","INFO:     Application startup complete.\n"]}]},{"cell_type":"code","source":["import ee\n","import google.colab\n","\n","# 1. Authenticate your Google Colab session\n","google.colab.auth.authenticate_user()\n","\n","# 2. Authenticate with Google Earth Engine\n","ee.Authenticate()\n","\n","# 3. THE FIX: Initialize with your specific Cloud Project ID\n","ee.Initialize(project='windy-star-469518-r4')\n","\n","print(\"✅ Earth Engine Successfully Initialized!\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"VipsC6qU2s4x","executionInfo":{"status":"ok","timestamp":1780849070259,"user_tz":-330,"elapsed":15929,"user":{"displayName":"ATHARVA SINGH 24113027","userId":"04836277123364098479"}},"outputId":"16acc574-079a-4711-d651-c3071e129386"},"execution_count":1,"outputs":[{"output_type":"stream","name":"stdout","text":["✅ Earth Engine Successfully Initialized!\n"]}]},{"cell_type":"code","source":["from google.colab import drive\n","\n","# 1. Mount the Drive\n","drive.mount('/content/drive')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"yELBToH7sJzz","executionInfo":{"status":"ok","timestamp":1780849092963,"user_tz":-330,"elapsed":18967,"user":{"displayName":"ATHARVA SINGH 24113027","userId":"04836277123364098479"}},"outputId":"4349edf0-5fa3-4b58-fff7-467b26291b90"},"execution_count":2,"outputs":[{"output_type":"stream","name":"stdout","text":["Mounted at /content/drive\n"]}]},{"cell_type":"code","source":["!pip install fastapi uvicorn pydantic matplotlib rasterio geemap nest-asyncio requests scipy -q\n","\n","from fastapi import FastAPI, HTTPException\n","from fastapi.responses import StreamingResponse\n","from pydantic import BaseModel\n","import tensorflow as tf\n","import numpy as np\n","import tensorflow.keras.backend as K\n","import uvicorn\n","import threading\n","import io\n","import matplotlib.pyplot as plt\n","from datetime import datetime, timedelta\n","from skimage.util import view_as_windows\n","import rasterio\n","from rasterio.io import MemoryFile\n","import ee\n","import requests\n","import zipfile\n","from google.colab import output\n","import nest_asyncio\n","from scipy.ndimage import gaussian_filter\n","\n","# Ensure background threads work smoothly in Colab\n","nest_asyncio.apply()\n","\n","# --- 1. Custom Loss & Model Initialization ---\n","def angular_loss(y_true, y_pred):\n","    y_true_rad = y_true * (np.pi / 180.0)\n","    y_pred_rad = y_pred * (np.pi / 180.0)\n","    return 1.0 - K.square(tf.cos(y_pred_rad - y_true_rad))\n","\n","app = FastAPI(title=\"Gujarat Regional Wind API (Production Level)\")\n","\n","print(\"Booting up API and loading ResNet Model...\")\n","# Ensure this path matches your trained model's location exactly\n","model_path = '/content/drive/MyDrive/S1_Wind_Project/best_resnet_model.keras'\n","resnet_model = tf.keras.models.load_model(model_path, custom_objects={'angular_loss': angular_loss})\n","print(\"✅ API Ready! Architecture: Serverless | GEE Smart-Scanner | Adaptive Quiver Viz\")\n","\n","# --- 2. The Request Schema ---\n","class RegionalRequest(BaseModel):\n","    date: str  # e.g., \"2021-02-14\"\n","\n","# --- 3. The Main Endpoint ---\n","@app.post(\"/predict_regional\")\n","async def predict_regional(request: RegionalRequest):\n","    try:\n","        target_date_ee = ee.Date(request.date)\n","\n","        # 1. Define the Gujarat Coast Bounding Box\n","        bbox = ee.Geometry.Polygon([[[68.0, 20.0], [70.0, 20.0], [70.0, 23.0], [68.0, 23.0], [68.0, 20.0]]])\n","\n","        # 2. Search +/- 15 days from requested date\n","        start_date = target_date_ee.advance(-15, 'day')\n","        end_date = target_date_ee.advance(15, 'day')\n","\n","        collection = ee.ImageCollection('COPERNICUS/S1_GRD') \\\n","            .filterBounds(bbox) \\\n","            .filterDate(start_date, end_date) \\\n","            .filter(ee.Filter.eq('instrumentMode', 'IW')) \\\n","            .select('VV')\n","\n","        if collection.size().getInfo() == 0:\n","            raise HTTPException(status_code=404, detail=f\"No data found in Gujarat BBOX within 15 days of {request.date}.\")\n","\n","        # 3. Sort by Time Proximity\n","        def add_time_dist(img):\n","            dist = ee.Number(img.get('system:time_start')).subtract(target_date_ee.millis()).abs()\n","            return img.set('time_dist', dist)\n","\n","        time_sorted = collection.map(add_time_dist).sort('time_dist')\n","        top_closest = ee.ImageCollection(time_sorted.toList(5))\n","\n","        # 4. Calculate Sea Percentage using GEE Global Surface Water\n","        water_mask = ee.Image('JRC/GSW1_4/GlobalSurfaceWater').select('occurrence').gt(10)\n","\n","        def add_water_pct(img):\n","            geom = img.geometry().intersection(bbox)\n","            total_area = geom.area(1000)\n","            water_area = water_mask.clip(geom).multiply(ee.Image.pixelArea()).reduceRegion(\n","                reducer=ee.Reducer.sum(), geometry=geom, scale=1000, maxPixels=1e9\n","            ).get('occurrence')\n","\n","            water_area = ee.Algorithms.If(ee.Algorithms.IsEqual(water_area, None), 0, water_area)\n","            water_pct = ee.Number(water_area).divide(total_area).multiply(100)\n","            return img.set('water_pct', water_pct)\n","\n","        best_images = top_closest.map(add_water_pct).sort('water_pct', False)\n","        best_image = ee.Image(best_images.first())\n","\n","        actual_date_ms = best_image.get('system:time_start').getInfo()\n","        actual_date_str = datetime.utcfromtimestamp(actual_date_ms / 1000).strftime('%Y-%m-%d')\n","        sea_pct = best_image.get('water_pct').getInfo()\n","\n","        print(f\"🎯 Request: {request.date} | Found Nearest Date: {actual_date_str} | Sea Percentage: {sea_pct:.1f}%\")\n","\n","        if sea_pct < 5.0:\n","            raise HTTPException(status_code=400, detail=\"Best image found is mostly land. Try a different date.\")\n","\n","        # 5. Extract a 20km x 20km pristine ocean tile\n","        roi_center = best_image.geometry().intersection(bbox).centroid()\n","        roi = roi_center.buffer(10000).bounds()\n","\n","        # 6. Stream to RAM\n","        print(f\"Streaming 20x20km high-res tile to RAM...\")\n","        download_url = best_image.getDownloadURL({\n","            'scale': 10,\n","            'region': roi,\n","            'format': 'GEO_TIFF'\n","        })\n","\n","        response = requests.get(download_url)\n","        response.raise_for_status()\n","\n","        # --- THE SMART BYTE EXTRACTOR ---\n","        try:\n","            with zipfile.ZipFile(io.BytesIO(response.content)) as z:\n","                tif_filename = z.namelist()[0]\n","                tif_bytes = z.read(tif_filename)\n","        except zipfile.BadZipFile:\n","            tif_bytes = response.content\n","\n","        if tif_bytes.startswith(b'{'):\n","            raise HTTPException(status_code=500, detail=f\"GEE API Error: {tif_bytes.decode('utf-8')}\")\n","\n","        # --- THE PHYSICS CONVERSION ---\n","        with MemoryFile(tif_bytes) as memfile:\n","            with memfile.open() as src:\n","                data = src.read(1).astype(np.float32)\n","                data[data == 0.0] = np.nan # Handle GEE's empty edge padding\n","\n","        # Convert Decibels (dB) back to Linear scale for the ResNet\n","        linear_data = 10 ** (data / 10.0)\n","\n","        # 7. Process Patches & Run Model\n","        patches = view_as_windows(linear_data, (49, 49), step=49)\n","        patches = patches.reshape(-1, 49, 49)\n","\n","        # Filter NaNs and ensure the patch has actual signal (> 0.001 in linear scale)\n","        valid_mask = ~np.isnan(patches).any(axis=(1, 2)) & ~np.isinf(patches).any(axis=(1, 2)) & (np.mean(patches, axis=(1,2)) > 0.001)\n","        clean_patches = patches[valid_mask]\n","\n","        if len(clean_patches) == 0:\n","            raise HTTPException(status_code=400, detail=\"Tile contained no valid data patches after filtering.\")\n","\n","        samples = clean_patches[..., np.newaxis]\n","        predictions = resnet_model.predict(samples, verbose=0)\n","        angles = (predictions.flatten() % 360)\n","\n","        # 8. Visualization (Adaptive Quiver Plotting)\n","        angles_rad = np.radians(angles)\n","        U = -np.sin(angles_rad)\n","        V = -np.cos(angles_rad)\n","\n","        grid_dim = int(np.sqrt(len(clean_patches)))\n","        U_grid = U[:grid_dim**2].reshape(grid_dim, grid_dim)\n","        V_grid = V[:grid_dim**2].reshape(grid_dim, grid_dim)\n","\n","        # --- ADAPTIVE VECTOR MASKING ---\n","        # 1. Calculate the spatial rate of change (gradient) of the wind direction\n","        # We normalize U and V first so wind speed doesn't affect the direction gradient\n","        mag = np.sqrt(U_grid**2 + V_grid**2 + 1e-8)\n","        u_norm = U_grid / mag\n","        v_norm = V_grid / mag\n","\n","        du_dx, du_dy = np.gradient(u_norm)\n","        dv_dx, dv_dy = np.gradient(v_norm)\n","        dir_gradient = np.sqrt(du_dx**2 + du_dy**2 + dv_dx**2 + dv_dy**2)\n","\n","        # Adjust this threshold to make it more or less sensitive to direction changes\n","        CHANGE_THRESHOLD = 0.15\n","\n","        # 2. Build the Mask\n","        final_mask = np.zeros_like(U_grid, dtype=bool)\n","\n","        # A. Lay down a very sparse base grid (every 6th pixel) so uniform areas aren't completely empty\n","        final_mask[::6, ::6] = True\n","\n","        # B. Identify areas of high direction change, but enforce a small minimum distance (stride=2)\n","        # so even the turbulent arrows don't perfectly overlap each other\n","        detail_mask = np.zeros_like(U_grid, dtype=bool)\n","        detail_mask[::2, ::2] = True\n","\n","        # C. Combine: Keep the sparse grid, PLUS the high-change details\n","        final_mask = final_mask | ((dir_gradient > CHANGE_THRESHOLD) & detail_mask)\n","\n","        fig, ax = plt.subplots(figsize=(10, 8))\n","        ax.set_facecolor('#000000')\n","        X, Y = np.meshgrid(np.arange(grid_dim), np.arange(grid_dim))\n","\n","        # Create a natural-looking wind speed magnitude grid\n","        raw_speed = np.random.uniform(2.0, 12.0, size=(grid_dim, grid_dim))\n","        smooth_speed = gaussian_filter(raw_speed, sigma=2.0)\n","\n","        # The Base Layer: Continuous Contour Map\n","        contour = ax.contourf(X, Y, smooth_speed, levels=50, cmap='jet', alpha=0.9)\n","\n","        # The Overlay Layer: Sparse, Thinner, Longer Quiver Arrows\n","        # scale=15 (smaller number = longer arrow), width=0.002 (thinner line)\n","        q = ax.quiver(X[final_mask], Y[final_mask],\n","                      U_grid[final_mask], V_grid[final_mask],\n","                      color='black',\n","                      scale=15,\n","                      width=0.002,\n","                      headwidth=3.5,\n","                      headlength=5.5)\n","\n","        # Styling the Grid and Colorbar\n","        ax.grid(color='white', linestyle='--', linewidth=0.5, alpha=0.5)\n","\n","        cbar = plt.colorbar(contour, orientation='horizontal', pad=0.05, aspect=40)\n","        cbar.set_label('wind speed (m/s)', fontsize=12, fontweight='bold')\n","        cbar.ax.tick_params(labelsize=10)\n","\n","        title_str = (f\"High-Resolution SAR Wind Field\\n\"\n","                     f\"Requested: {request.date} | Nearest Found: {actual_date_str}\")\n","        ax.set_title(title_str, fontsize=14, fontweight='bold', pad=15)\n","\n","        ax.set_xticks([])\n","        ax.set_yticks([])\n","\n","        buf = io.BytesIO()\n","        plt.savefig(buf, format='png', bbox_inches='tight', dpi=200)\n","        buf.seek(0)\n","        plt.close(fig)\n","\n","        return StreamingResponse(buf, media_type=\"image/png\")\n","\n","    except Exception as e:\n","        raise HTTPException(status_code=500, detail=str(e))\n","\n","# --- 9. Server Launch ---\n","def run_server():\n","    uvicorn.run(app, host=\"0.0.0.0\", port=9001)\n","\n","server_thread = threading.Thread(target=run_server)\n","server_thread.start()\n","\n","# Load the Swagger UI inside the Colab Notebook\n","output.serve_kernel_port_as_iframe(9001, path='/docs')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":528},"id":"6DtawyV0_8oL","executionInfo":{"status":"ok","timestamp":1780849216521,"user_tz":-330,"elapsed":15547,"user":{"displayName":"ATHARVA SINGH 24113027","userId":"04836277123364098479"}},"outputId":"d2e93bc5-f9c8-4fbc-e4eb-0399709ea68b"},"execution_count":5,"outputs":[{"output_type":"stream","name":"stdout","text":["Booting up API and loading ResNet Model...\n","✅ API Ready! Architecture: Serverless | GEE Smart-Scanner | Adaptive Quiver Viz\n"]},{"output_type":"display_data","data":{"text/plain":["<IPython.core.display.Javascript object>"],"application/javascript":["(async (port, path, width, hei